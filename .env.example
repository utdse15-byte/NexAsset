VITE_APP_DEFAULT_ROUTE = /dashboard/workbench
VITE_APP_PUBLIC_PATH = /
VITE_APP_API_BASE_URL = /api
# 路由模式:
# - backend (默认, 推荐): 菜单 / 路由从 DB_MENU 生成, 即 NexAsset 的真实业务菜单
#   (资产 / 采购 / 耗材 / 用户 / 部门 / 审计 / 仪表盘)。这是产品默认形态。
# - frontend: 显示 slash-admin 模板自带的演示菜单 (Components / Menu Level /
#   Iframe 等), 仅用于检视基底模板时使用。
VITE_APP_ROUTER_MODE = backend

# AI 后端地址。留空 = 走同源 /api/ai (推荐, 由 Nginx/Vite 反代)。
# 仅在前端直连后端调试时设为 http://localhost:8000。
# ⚠️ VITE_* 变量会被打进前端 bundle, 公开可见, 永远不要放密钥!
VITE_AI_BACKEND_URL =
