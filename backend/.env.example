# NexAsset AI Backend 环境变量
# 复制为 .env 并填入真实值

# ── OpenAI ────────────────────────────────────────
# 必填
OPENAI_API_KEY=sk-your-api-key-here
# 可选: 自定义 endpoint (例如代理或 Azure OpenAI)
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选: 模型名
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# ── 安全 ──────────────────────────────────────────
# 跨域来源 (留空 = 仅同源, 推荐)。多个用逗号分隔, 例如:
# ALLOWED_ORIGINS=https://nexasset.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# 速率限制 (按客户端 IP)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# 信任反向代理转发的 X-Forwarded-For 头 (用于按真实 IP 限流)。
# - true: 部署在 Nginx/CDN 等反代后必须开启
# - false (默认): 直接暴露后端端口或单机调试时, 防止伪造头绕过限流
# TRUST_FORWARDED_FOR=false

# 管理员 token: 用于 POST /api/ai/reindex (留空则该端点直接 503)
# ADMIN_TOKEN=please-change-me

# ── 会话 ──────────────────────────────────────────
MAX_HISTORY_LENGTH=20
MAX_SESSIONS=100

# ── 日志 ──────────────────────────────────────────
LOG_LEVEL=INFO
